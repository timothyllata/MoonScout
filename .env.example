# NeuroScout — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ------------------------------------------------------------
# MongoDB Atlas  (required — Atlas Prize Track PC-10)
# Get your connection string from: Atlas UI > Connect > Drivers
# Must use the mongodb+srv:// scheme (Atlas, NOT localhost)
# ------------------------------------------------------------
MONGODB_CONNECTION_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=neurosciout

# ------------------------------------------------------------
# Solana / Helius RPC
# Free API key: https://dev.helius.xyz/dashboard
# ------------------------------------------------------------
HELIUS_API_KEY=your_helius_api_key_here

# ScoutAgent poll interval in seconds (default: 60)
SCOUT_POLL_INTERVAL=60.0

# ------------------------------------------------------------
# Telegram Bot
# Create a bot via @BotFather, then get your chat ID via
# https://api.telegram.org/bot<TOKEN>/getUpdates
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789

# ------------------------------------------------------------
# Discord Incoming Webhook
# Server Settings > Integrations > Webhooks > New Webhook
# ------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>

# ------------------------------------------------------------
# X / Twitter API v2  (OAuth 1.0a — User Context required for posting)
# Developer portal: https://developer.twitter.com/en/portal
# Requires "Read and Write" app permissions
# ------------------------------------------------------------
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret

# ------------------------------------------------------------
# uagents — Agent Seeds
# Each seed deterministically derives the agent's address and keypair.
# Use any random string (min 32 chars recommended).
# Keep these SECRET — they control agent identity on the Fetch.ai network.
# ------------------------------------------------------------
SCOUT_SEED=scout_replace_with_random_secret_seed_32chars
HISTORIAN_SEED=historian_replace_with_random_secret_seed_32chars
ANALYST_SEED=analyst_replace_with_random_secret_seed_32chars
TELEGRAM_AGENT_SEED=telegram_replace_with_random_secret_seed_32chars
DISCORD_AGENT_SEED=discord_replace_with_random_secret_seed_32chars
X_AGENT_SEED=x_replace_with_random_secret_seed_32chars

# ------------------------------------------------------------
# ML / Scoring Config  (optional — defaults shown)
# ------------------------------------------------------------
# Minimum Degen Score (0–100) to save intelligence doc and broadcast
DEGEN_SCORE_THRESHOLD=70.0
